# Tarzan's Barbershop — example env. Copy to .env and fill in.
#
# In Vercel, set these via the dashboard (Project Settings -> Environment Variables).
# Use the Vercel Postgres / Neon integration to auto-set DATABASE_URL.

# Postgres connection string (provided automatically by Vercel Postgres / Neon integration)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Google Calendar (optional) -----------------------------------------------
# Either set GOOGLE_CREDENTIALS_JSON (full JSON content as a string) — required on Vercel.
# Or, in local dev, drop the service-account file at /google-credentials.json (gitignored).
# Without these the booking flow still works — events just won't sync to Calendar.
GOOGLE_CREDENTIALS_JSON=""
GCAL_CALENDAR_ID="xxxxxxxxxxxxxxxxxxxxxxx@group.calendar.google.com"

# ---- Shop info ----------------------------------------------------------------
# International phone WITHOUT "+" (e.g., 351912345678). Public — used in wa.me link.
NEXT_PUBLIC_SHOP_PHONE="351912345678"
