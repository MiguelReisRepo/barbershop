# Tarzan's Barbershop — example env. Copy to .env and fill in.
#
# In Vercel, set these via the dashboard (Project Settings -> Environment Variables).
# Use the Vercel Postgres / Neon integration to auto-set DATABASE_URL.

# Postgres connection string (provided automatically by Vercel Postgres / Neon integration)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Email (Resend) -----------------------------------------------------------
# Sign up at https://resend.com to get a key. Free tier: 100 emails/day.
# Without a verified domain, you can only send to the email used in the Resend account.
# For full functionality (sending to any customer), verify a domain in Resend.
RESEND_API_KEY=""
# Optional override of the From address (must be on a verified domain)
EMAIL_FROM="Tarzan's Barbershop <onboarding@resend.dev>"
# Where new-booking notifications are sent (the barber's inbox)
ADMIN_EMAIL="tarzans.barbershop@gmail.com"

# Public site URL — used to build links inside emails. Auto-set on Vercel
# from VERCEL_PROJECT_PRODUCTION_URL; only override if you need to.
NEXT_PUBLIC_SITE_URL=""

# ---- Google Calendar (optional) -----------------------------------------------
GOOGLE_CREDENTIALS_JSON=""
GCAL_CALENDAR_ID="xxxxxxxxxxxxxxxxxxxxxxx@group.calendar.google.com"

# ---- Cron jobs ----------------------------------------------------------------
# Vercel sends `Authorization: Bearer <CRON_SECRET>` to cron endpoints. Generate
# any random string and set it both here and in Vercel project settings.
CRON_SECRET=""

# ---- Shop info ----------------------------------------------------------------
NEXT_PUBLIC_SHOP_PHONE="351912345678"
